@page "/"
@using XCoinBlazor.Services
@using XCoinBlazor.Models
@inject CryptoDataService CryptoDataService
@inject IJSRuntime JSRuntime

<PageTitle>Cryptocurrency Price Tracker</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-4">Cryptocurrency Monthly Prices</h1>
            <p class="lead">Track monthly average prices for the last 5 years</p>
        </div>
    </div>

    <!-- Cryptocurrency Selection -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <label for="cryptoSelect" class="form-label">Select Cryptocurrency:</label>
                    <select id="cryptoSelect" class="form-select" @bind="selectedCrypto">
                        @foreach (var crypto in availableCryptos)
                        {
                            <option value="@crypto.Name">@crypto.DisplayName (@crypto.Symbol)</option>
                        }
                    </select>
                    <button class="btn btn-primary mt-2" @onclick="LoadSelectedCrypto">Load Data</button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="row">
            <div class="col text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2">Loading cryptocurrency data...</p>
            </div>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="row">
            <div class="col">
                <div class="alert alert-danger" role="alert">
                    <strong>Error:</strong> @errorMessage
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h5 class="card-title">Total Years</h5>
                        <h2>@stats.totalYears</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h5 class="card-title">Average Price</h5>
                        <h2>$@stats.average.ToString("N0")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <h5 class="card-title">Highest Price</h5>
                        <h2>$@stats.highest.ToString("N0")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <h5 class="card-title">Lowest Price</h5>
                        <h2>$@stats.lowest.ToString("N0")</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart -->
        <div class="row mb-4">
            <div class="col">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Monthly Price Chart</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="priceChart" width="400" height="200"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Data Table -->
        <div class="row">
            <div class="col">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Monthly Price Data</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Year</th>
                                        <th>Jan</th>
                                        <th>Feb</th>
                                        <th>Mar</th>
                                        <th>Apr</th>
                                        <th>May</th>
                                        <th>Jun</th>
                                        <th>Jul</th>
                                        <th>Aug</th>
                                        <th>Sep</th>
                                        <th>Oct</th>
                                        <th>Nov</th>
                                        <th>Dec</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var yearData in monthlyData.OrderByDescending(x => x.Key))
                                    {
                                        <tr>
                                            <td><strong>@yearData.Key</strong></td>
                                            @for (int month = 1; month <= 12; month++)
                                            {
                                                <td>
                                                    @if (yearData.Value.TryGetValue(month, out var price) && price > 0)
                                                    {
                                                        @($"${price:N0}")
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private Dictionary<int, Dictionary<int, double>> monthlyData = new();
    private (int totalYears, double average, double highest, double lowest) stats;
    private string selectedCrypto = "bitcoin";
    private List<CryptoCurrency> availableCryptos = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            availableCryptos = CryptoDataService.GetAvailableCryptocurrencies();
            await LoadData();
        }
    }

    private async Task LoadSelectedCrypto()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            monthlyData = await CryptoDataService.LoadMonthlyAveragesAsync(selectedCrypto);

            if (monthlyData.Any())
            {
                var calculatedStats = CryptoDataService.CalculateStats(monthlyData);
                stats = (monthlyData.Count, calculatedStats.avg, calculatedStats.max, calculatedStats.min);

                // Initialize chart after data is loaded
                await Task.Delay(100); // Small delay to ensure DOM is ready
                await InitializeChart();
            }
            else
            {
                errorMessage = "No data available";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task InitializeChart()
    {
        try
        {
            // Prepare data for Chart.js
            var years = monthlyData.Keys.OrderBy(y => y).ToList();
            var monthNames = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
            var datasets = new List<object>();

            // Color palette
            var colors = new[]
            {
                "rgba(255, 99, 132, 1)",
                "rgba(54, 162, 235, 1)",
                "rgba(255, 205, 86, 1)",
                "rgba(75, 192, 192, 1)",
                "rgba(153, 102, 255, 1)",
                "rgba(255, 159, 64, 1)",
                "rgba(199, 199, 199, 1)",
                "rgba(83, 102, 255, 1)",
                "rgba(255, 99, 255, 1)",
                "rgba(99, 255, 132, 1)"
            };

            for (int i = 0; i < years.Count; i++)
            {
                var year = years[i];
                var yearData = monthlyData[year];
                var prices = new List<double>();

                for (int month = 1; month <= 12; month++)
                {
                    prices.Add(yearData.TryGetValue(month, out var price) ? price : 0);
                }

                datasets.Add(new
                {
                    label = year.ToString(),
                    data = prices,
                    borderColor = colors[i % colors.Length],
                    backgroundColor = colors[i % colors.Length].Replace("1)", "0.1)"),
                    borderWidth = 2,
                    fill = false,
                    tension = 0.1,
                    pointRadius = 3,
                    pointHoverRadius = 5
                });
            }

            var chartConfig = new
            {
                type = "line",
                data = new
                {
                    labels = monthNames,
                    datasets = datasets
                },
                options = new
                {
                    responsive = true,
                    maintainAspectRatio = false,
                    plugins = new
                    {
                        title = new
                        {
                            display = true,
                            text = "Cryptocurrency Monthly Average Prices",
                            font = new { size = 16 }
                        },
                        legend = new
                        {
                            display = true,
                            position = "top"
                        },
                        tooltip = new
                        {
                            mode = "index",
                            intersect = false,
                            callbacks = new
                            {
                                label = "function(context) { let label = context.dataset.label || ''; if (label) { label += ': '; } if (context.parsed.y !== null) { label += '$' + context.parsed.y.toLocaleString(); } return label; }"
                            }
                        }
                    },
                    scales = new
                    {
                        y = new
                        {
                            beginAtZero = false,
                            ticks = new
                            {
                                callback = "function(value) { return '$' + value.toLocaleString(); }"
                            },
                            title = new
                            {
                                display = true,
                                text = "Price (USD)"
                            }
                        },
                        x = new
                        {
                            title = new
                            {
                                display = true,
                                text = "Month"
                            }
                        }
                    },
                    interaction = new
                    {
                        mode = "nearest",
                        axis = "x",
                        intersect = false
                    }
                }
            };

            await JSRuntime.InvokeVoidAsync("renderChart", "priceChart", chartConfig);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Chart initialization error: {ex.Message}");
        }
    }
}
