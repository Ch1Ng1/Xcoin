@page "/"
@using XCoinBlazor.Models
@inject HttpClient Http
@inject IJSRuntime JS

<h3>Bitcoin Monthly Chart</h3>

@if (isLoading)
{
    <p>Loading chart data...</p>
}
else if (hasError)
{
    <p>Error loading chart data. Please try again.</p>
}
else
{
    <canvas id="priceChart" width="800" height="400"></canvas>
}

@code {
    private object? chartConfig;
    private bool isLoading = true;
    private bool hasError = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var data = await Http.GetFromJsonAsync<List<MonthStat>>("data/month-stats.json");

            if (data == null || !data.Any())
            {
                hasError = true;
                return;
            }

            // Group data by year and month
            var monthlyData = new Dictionary<string, Dictionary<int, double>>();
            foreach (var item in data)
            {
                var parts = item.Month.Split('-');
                if (parts.Length == 2 && int.TryParse(parts[0], out var year) && int.TryParse(parts[1], out var month))
                {
                    if (!monthlyData.ContainsKey(year.ToString()))
                    {
                        monthlyData[year.ToString()] = new Dictionary<int, double>();
                    }
                    monthlyData[year.ToString()][month] = (double)item.Price;
                }
            }

            chartConfig = monthlyData;
        }
        catch
        {
            hasError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && chartConfig != null)
        {
            await JS.InvokeVoidAsync("renderChart", "priceChart", chartConfig);
        }
    }
}
