@page "/"
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Text.Json

<div class="coin-header">
    <h3 class="coin-title">
        <span class="coin-icon">@coinIcons.GetValueOrDefault(selectedCoin, "💰")</span>
        @coinFullNames.GetValueOrDefault(selectedCoin, selectedCoin) Monthly Chart
    </h3>
    <button class="btn btn-outline-secondary btn-sm refresh-btn" @onclick="RefreshAsync" disabled="@isLoading" title="Refresh">
        <span class="@(isLoading ? "spin" : "")">⟳</span> Refresh
    </button>
</div>

<div class="coin-selector-row mb-3">
    <label class="form-label me-2 fw-semibold">Select Coin:</label>
    <div class="coin-buttons">
        @foreach (var coin in coinDataFiles.Keys)
        {
            <button class="btn coin-btn @(selectedCoin == coin ? "active" : "")"
                    @onclick="() => SelectCoinAsync(coin)">
                <span>@coinIcons.GetValueOrDefault(coin, "💰")</span>
                @coin
            </button>
        }
    </div>
</div>

@if (priceInfo is not null)
{
    <div class="price-info-row mb-3">
        <div class="price-card">
            <span class="price-label">Current Price</span>
            <span class="price-value">@FormatPrice(priceInfo.CurrentPrice)</span>
        </div>
        <div class="price-card">
            <span class="price-label">24h Change</span>
            <span class="price-change @(priceInfo.Change24h >= 0 ? "positive" : "negative")">
                @(priceInfo.Change24h >= 0 ? "▲" : "▼") @Math.Abs(priceInfo.Change24h).ToString("F2")%
            </span>
        </div>
        <div class="price-card">
            <span class="price-label">24h High</span>
            <span class="price-value">@FormatPrice(priceInfo.High24h)</span>
        </div>
        <div class="price-card">
            <span class="price-label">24h Low</span>
            <span class="price-value">@FormatPrice(priceInfo.Low24h)</span>
        </div>
        @if (lastUpdated.HasValue)
        {
            <div class="price-card updated-card">
                <span class="price-label">Last Updated</span>
                <span class="price-updated">@lastUpdated.Value.ToLocalTime().ToString("HH:mm:ss")</span>
            </div>
        }
    </div>
}

@if (isLoading)
{
    <div class="loading-spinner">
        <div class="spinner"></div>
        <span>Loading chart data...</span>
    </div>
}
else if (hasError)
{
    <div class="alert alert-warning">
        <span>⚠️</span> Error loading chart data. <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="RefreshAsync">Try again</button>
    </div>
}
else
{
    <div class="chart-wrapper">
        <canvas id="priceChart"></canvas>
    </div>
}

@code {
    private object? chartConfig;
    private bool isLoading = true;
    private bool hasError;
    private bool shouldRenderChart;
    private string selectedCoin = "BTC";
    private PriceInfo? priceInfo;
    private DateTime? lastUpdated;

    private readonly Dictionary<string, string> coinDataFiles = new()
    {
        ["BTC"] = "data/month-stats.json",
        ["ETH"] = "data/eth-month-stats.json",
        ["SOLANA"] = "data/solana-month-stats.json",
        ["XRP"] = "data/xrp-month-stats.json",
        ["DOGE"] = "data/doge-month-stats.json",
        ["SHIB"] = "data/shib-month-stats.json"
    };
    private readonly Dictionary<string, string> coinApiIds = new()
    {
        ["BTC"] = "bitcoin",
        ["ETH"] = "ethereum",
        ["SOLANA"] = "solana",
        ["XRP"] = "ripple",
        ["DOGE"] = "dogecoin",
        ["SHIB"] = "shiba-inu"
    };
    private readonly Dictionary<string, string> coinFullNames = new()
    {
        ["BTC"] = "Bitcoin",
        ["ETH"] = "Ethereum",
        ["SOLANA"] = "Solana",
        ["XRP"] = "XRP",
        ["DOGE"] = "Dogecoin",
        ["SHIB"] = "Shiba Inu"
    };
    private readonly Dictionary<string, string> coinIcons = new()
    {
        ["BTC"] = "₿",
        ["ETH"] = "Ξ",
        ["SOLANA"] = "◎",
        ["XRP"] = "✕",
        ["DOGE"] = "Ð",
        ["SHIB"] = "🐕"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadChartDataAsync(selectedCoin);
    }

    private async Task OnSelectedCoinChangedAsync()
    {
        await SelectCoinAsync(selectedCoin);
    }

    private async Task RefreshAsync()
    {
        await LoadChartDataAsync(selectedCoin);
    }

    private async Task SelectCoinAsync(string coin)
    {
        selectedCoin = coin;
        await LoadChartDataAsync(coin);
    }

    private string FormatPrice(decimal price)
    {
        if (price < 0.001m) return "$" + price.ToString("F8");
        if (price < 1m) return "$" + price.ToString("F4");
        if (price < 1000m) return "$" + price.ToString("F2");
        return "$" + price.ToString("N0");
    }

    private async Task LoadChartDataAsync(string coin)
    {
        isLoading = true;
        hasError = false;
        priceInfo = null;
        StateHasChanged();

        try
        {
            if (!coinDataFiles.TryGetValue(coin, out var dataFile))
            {
                hasError = true;
                return;
            }

            var yearlyValues = await Http.GetFromJsonAsync<Dictionary<string, List<decimal>>>(dataFile);
            var currentYear = DateTime.UtcNow.Year;
            var currentYearKey = currentYear.ToString();

            if (yearlyValues is null || yearlyValues.Count == 0)
            {
                hasError = true;
                return;
            }

            if (coinApiIds.TryGetValue(coin, out var coinApiId))
            {
                var apiCurrentYearValues = await TryGetCurrentYearValuesAsync(coinApiId, currentYear);
                if (apiCurrentYearValues is not null && apiCurrentYearValues.Count > 0)
                {
                    yearlyValues[currentYearKey] = apiCurrentYearValues;
                }

                priceInfo = await TryGetPriceInfoAsync(coinApiId);
                lastUpdated = DateTime.UtcNow;
            }

            var firstYear = 2022;
            var lastYear = Math.Max(firstYear, currentYear);
            var allowedYears = Enumerable.Range(firstYear, lastYear - firstYear + 1).Select(year => year.ToString());
            var monthlyData = new Dictionary<string, Dictionary<int, double>>();

            foreach (var year in allowedYears)
            {
                if (!yearlyValues.TryGetValue(year, out var values))
                {
                    continue;
                }

                if (values.Count == 0)
                {
                    hasError = true;
                    return;
                }

                var maxMonths = year == currentYearKey ? DateTime.UtcNow.Month : 12;
                var monthCount = Math.Min(maxMonths, values.Count);

                if (monthCount == 0)
                {
                    continue;
                }

                monthlyData[year] = values
                    .Take(monthCount)
                    .Select((value, index) => new { Month = index + 1, Price = (double)value })
                    .ToDictionary(item => item.Month, item => item.Price);
            }

            if (monthlyData.Count == 0)
            {
                hasError = true;
                return;
            }

            chartConfig = monthlyData;
            shouldRenderChart = true;
        }
        catch
        {
            hasError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldRenderChart && chartConfig is not null)
        {
            var isDark = await JS.InvokeAsync<bool>("darkMode.isDark");
            await JS.InvokeVoidAsync("renderChart", "priceChart", chartConfig, isDark);
            shouldRenderChart = false;
        }
    }

    private static async Task<List<decimal>?> TryGetCurrentYearValuesAsync(string coinApiId, int year)
    {
        try
        {
            var from = new DateTimeOffset(new DateTime(year, 1, 1, 0, 0, 0, DateTimeKind.Utc)).ToUnixTimeSeconds();
            var to = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
            var url = $"https://api.coingecko.com/api/v3/coins/{coinApiId}/market_chart/range?vs_currency=usd&from={from}&to={to}";

            using var apiClient = new HttpClient();
            using var response = await apiClient.GetAsync(url);

            if (!response.IsSuccessStatusCode)
            {
                return null;
            }

            using var responseStream = await response.Content.ReadAsStreamAsync();
            using var json = await JsonDocument.ParseAsync(responseStream);

            if (!json.RootElement.TryGetProperty("prices", out var pricesElement) || pricesElement.ValueKind != JsonValueKind.Array)
            {
                return null;
            }

            var monthlyValues = new Dictionary<int, List<decimal>>();

            foreach (var point in pricesElement.EnumerateArray())
            {
                if (point.ValueKind != JsonValueKind.Array || point.GetArrayLength() < 2)
                {
                    continue;
                }

                var timestampMilliseconds = point[0].GetDouble();
                var price = point[1].GetDouble();
                var date = DateTimeOffset.FromUnixTimeMilliseconds((long)timestampMilliseconds).UtcDateTime;

                if (date.Year != year)
                {
                    continue;
                }

                if (!monthlyValues.TryGetValue(date.Month, out var monthList))
                {
                    monthList = new List<decimal>();
                    monthlyValues[date.Month] = monthList;
                }

                monthList.Add((decimal)price);
            }

            var currentMonth = DateTime.UtcNow.Month;
            var result = new List<decimal>();

            for (var month = 1; month <= currentMonth; month++)
            {
                if (!monthlyValues.TryGetValue(month, out var monthList) || monthList.Count == 0)
                {
                    break;
                }

                result.Add(monthList.Average());
            }

            return result.Count > 0 ? result : null;
        }
        catch
        {
            return null;
        }
    }

    private static async Task<PriceInfo?> TryGetPriceInfoAsync(string coinApiId)
    {
        try
        {
            var url = $"https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&ids={coinApiId}&price_change_percentage=24h";
            using var apiClient = new HttpClient();
            using var response = await apiClient.GetAsync(url);
            if (!response.IsSuccessStatusCode) return null;

            using var stream = await response.Content.ReadAsStreamAsync();
            using var json = await JsonDocument.ParseAsync(stream);
            var arr = json.RootElement;
            if (arr.ValueKind != JsonValueKind.Array || arr.GetArrayLength() == 0) return null;

            var item = arr[0];
            return new PriceInfo
            {
                CurrentPrice = item.TryGetProperty("current_price", out var cp) ? cp.GetDecimal() : 0,
                Change24h = item.TryGetProperty("price_change_percentage_24h", out var ch) ? (decimal)ch.GetDouble() : 0,
                High24h = item.TryGetProperty("high_24h", out var hi) ? hi.GetDecimal() : 0,
                Low24h = item.TryGetProperty("low_24h", out var lo) ? lo.GetDecimal() : 0
            };
        }
        catch
        {
            return null;
        }
    }

    private class PriceInfo
    {
        public decimal CurrentPrice { get; set; }
        public decimal Change24h { get; set; }
        public decimal High24h { get; set; }
        public decimal Low24h { get; set; }
    }
}
