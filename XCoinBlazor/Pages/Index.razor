@page "/"
@using XCoinBlazor.Models
@inject HttpClient Http
@inject IJSRuntime JS

<h3>Bitcoin Monthly Chart</h3>

@if (isLoading)
{
    <p>Loading chart data...</p>
}
else if (hasError)
{
    <p>Error loading chart data. Please try again.</p>
}
else
{
    <canvas id="myChart" width="800" height="400"></canvas>
}

@code {
    private object? chartConfig;
    private bool isLoading = true;
    private bool hasError = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var data = await Http.GetFromJsonAsync<List<MonthStat>>("data/month-stats.json");

            if (data == null || !data.Any())
            {
                hasError = true;
                return;
            }

            var labels = data.Select(x => x.Month).ToArray();
            var prices = data.Select(x => x.Price).ToArray();

            chartConfig = new
            {
                type = "line",
                data = new
                {
                    labels = labels,
                    datasets = new[]
                    {
                        new {
                            label = "BTC Price",
                            data = prices,
                            borderColor = "rgba(75, 192, 192, 1)",
                            backgroundColor = "rgba(75, 192, 192, 0.2)",
                            borderWidth = 2
                        }
                    }
                },
                options = new
                {
                    responsive = true,
                    maintainAspectRatio = false
                }
            };
        }
        catch
        {
            hasError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && chartConfig != null)
        {
            await JS.InvokeVoidAsync("renderChart", "myChart", chartConfig);
        }
    }
}
